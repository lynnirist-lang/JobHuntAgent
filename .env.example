# ============================================================
# 复制为 .env 并填入真实值（.env 已加入 .gitignore，不会提交到 git）
# ============================================================

# LLM API（兼容任意 OpenAI 协议的服务，默认 DeepSeek）
# 也可以用 LLM_API_KEY / LLM_MODEL / LLM_BASE_URL 覆盖
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 数据库路径（相对于项目根目录）
DATABASE_URL=sqlite+aiosqlite:///./data/jobs.db

# BOSS 直聘 Cookie 持久化路径
BOSS_COOKIES_PATH=./data/boss_cookies.json

# 搜索配置（逗号分隔的关键词）
BOSS_SEARCH_KEYWORDS=AI全栈
BOSS_SEARCH_CITY=广州
BOSS_SEARCH_SALARY=7-25k

# 投递安全限制
DAILY_APPLY_LIMIT=20        # 单日最多投递数
APPLY_DELAY_MEAN=4.0        # Gaussian 延迟均值（秒）
APPLY_DELAY_STD=1.5         # Gaussian 延迟标准差（秒）
APPLY_DELAY_MIN=1.5         # 最小延迟下限（秒）

# HuggingFace 离线模式（模型已缓存后可开启，避免企业网络 SSL 报错）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=3001
